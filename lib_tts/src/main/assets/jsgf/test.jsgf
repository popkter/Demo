)"</number_>"
);

<fmFreqValue>=(
"<fmFreqValue_>"(
	("<prefix_>" 八[十](七|八|九)["<unk>"] "</prefix_>")
	| (八[十](七|八|九)点<number>)
	| ("<prefix_>" 九[十]<number>["<unk>"] "</prefix_>")
	| (九[十]<number>点<number>)
	| (九十点<number>)
	| ("<prefix_>" 一[百]零(零|一|二|三|四|五|六|七|八)["<unk>"] "<prefix_>")
	| (一[百]零(零|一|二|三|四|五|六|七|八)点<number>)
	| ("<prefix_>" 一百["<unk>"] "<prefix_>")
	| (一百点<number>)
)"</fmFreqValue_>"
);

<amFreqValue>=(
"<amFreqValue_>"(
	("<prefix_>" 五百(三|四|五|六|七|八|九)[十]["<unk>"] "<prefix_>")
	| ("<prefix_>" 五[百](三|四|五|六|七|八|九)[十]<number>["<unk>"] "<prefix_>")
	| ("<prefix_>" (六|七|八|九)百[(一|二|三|四|五|六|七|八|九)[十]]["<unk>"] "<prefix_>")
	| ("<prefix_>" (六|七|八|九)[百]零<number>["<unk>"] "<prefix_>")
	| ("<prefix_>" (六|七|八|九)[百](<number>)[十](<number>)["<unk>"] "<prefix_>")
	| (一千零<number>[十]["<unk>"])
	| (一千(一|二|三|四|五|六)[百]["<unk>"])
    | (一千(一|二|三|四|五)百<number>[十]["<unk>"])
    | (一千(一|二|三|四|五)百<number>十<number>)
	| (一(零|一|二|三|四|五)<number><number>)
	| (一千六百(零|一|二)[十]["<unk>"])
    | (一千六百(零|一|二)十<number>)
	| (一六(零|一|二)<number>)
)"</amFreqValue_>"
);


